# Local secrets and machine-specific config
/config.local.json
/litellm-config.yaml
/start-claude-deepseek.ps1

# Legacy/local desktop app code, kept local but not synced to GitHub
/app/
/legacy/
/run_daily_note.bat
/run_daily_note.pyw
/restart_daily_note.py

# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class

# Runtime indexes, logs, and generated local state
/workspace/indexes/
/workspace/data/
/workspace/experiments/
/workspace/literature/
/workspace/notes/
/workspace/reports/
/workspace/users/*/indexes/
/workspace/users/*/notes/
/.codex-remote-attachments/
/tmp/

# Code/workflow directories stay versioned
!/workspace/scripts/
!/workspace/scripts/**
!/workspace/skills/
!/workspace/skills/**
/workspace/scripts/**/__pycache__/
/workspace/scripts/**/*.pyc
/workspace/scripts/**/*.pyo

# Raw data and generated analysis artifacts
*.npz
*.mat
*.log
*.err
*.tmp
*.bak
*.csv
/workspace/scripts/**/results/
/workspace/scripts/**/outputs/

# Local scratch files and root-level reference PDFs
/hello_world.py
/*.pdf

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
